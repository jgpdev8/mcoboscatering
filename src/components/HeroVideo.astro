---
// Vimeo: https://vimeo.com/873447852
---
<section class="relative w-full overflow-hidden flex items-center justify-center" style="height: 100svh; min-height: 600px;">

  <!-- Vimeo Background -->
  <div class="absolute inset-0 w-full h-full">
    <div class="absolute inset-0" style="transform: scale(1.15);">
      <iframe
        id="vimeo-iframe"
        src="https://player.vimeo.com/video/873447852?background=1&autoplay=1&loop=1&muted=1&playsinline=1&quality=1080p"
        allow="autoplay; fullscreen"
        loading="lazy"
        title="Cobos Catering Presentación"
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);min-width:177.78vh;min-height:56.25vw;width:100vw;height:100vh;border:none;"
      ></iframe>
    </div>
    <!-- Poster fallback while loading -->
    <div id="video-poster" class="absolute inset-0 transition-opacity duration-1000" style="background: var(--color-dark-card);">
      <img
        src="https://images.unsplash.com/photo-1555244162-803834f70033?w=1920&q=80"
        alt=""
        class="w-full h-full object-cover"
        style="opacity: 0.6;"
        loading="eager"
      />
    </div>
  </div>

  <!-- Overlay gradients -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(17,17,17,0.4) 0%, transparent 50%, rgba(17,17,17,0.8) 100%);"></div>
  <div class="absolute inset-0" style="background: rgba(17,17,17,0.3);"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <p class="text-sm mb-6 hero-fade-1" style="font-family: var(--font-family-body); color: var(--color-gold); letter-spacing: 0.3em; text-transform: uppercase;">
      Bienvenidos
    </p>
    <h1 class="font-semibold text-white leading-none mb-8 hero-fade-2" style="font-family: var(--font-family-display); font-size: clamp(3rem, 10vw, 6rem);">
      Cobos<br/><span style="color: var(--color-gold);">Catering</span>
    </h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-12 hero-fade-3" style="font-family: var(--font-family-body); color: rgba(255,255,255,0.7);">
      Más de 30 años creando experiencias gastronómicas únicas para cada celebración
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center hero-fade-4">
      <a href="/contacto" class="btn-gold">Solicitar presupuesto</a>
      <a href="#servicios" class="inline-flex items-center gap-2 px-8 py-3 text-sm tracking-widest uppercase transition-all duration-300"
         style="border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8); font-family: var(--font-family-body); font-weight: 500;"
         onmouseover="this.style.borderColor='white'; this.style.color='white';"
         onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.color='rgba(255,255,255,0.8)';">
        Descubrir más
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color: rgba(255,255,255,0.4); animation: bounce 2s infinite;">
    <span class="text-xs tracking-widest uppercase" style="font-family: var(--font-family-body);">Scroll</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-8px); }
  }

  .hero-fade-1 { opacity: 0; animation: heroFadeIn 0.8s ease 0.5s forwards; }
  .hero-fade-2 { opacity: 0; animation: heroFadeIn 0.8s ease 0.8s forwards; }
  .hero-fade-3 { opacity: 0; animation: heroFadeIn 0.8s ease 1.1s forwards; }
  .hero-fade-4 { opacity: 0; animation: heroFadeIn 0.8s ease 1.4s forwards; }
</style>

<script>
  const poster = document.getElementById('video-poster')
  if (poster) {
    setTimeout(() => {
      poster.style.opacity = '0'
    }, 2000)
  }
</script>
