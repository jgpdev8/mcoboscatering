---
const events = [
  {
    title: 'Eventos Corporativos',
    description: 'Reuniones, conferencias y celebraciones empresariales con la excelencia que su empresa merece.',
    image: 'https://images.unsplash.com/photo-1511578314322-379afb476865?w=600&q=80',
    href: '/eventos',
  },
  {
    title: 'Espacios',
    description: 'Localizaciones únicas y versátiles adaptadas a cada tipo de celebración.',
    image: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=600&q=80',
    href: '/espacios',
  },
  {
    title: 'Catas Magistrales',
    description: 'Una experiencia sensorial con los mejores vinos y maridajes de la gastronomía mediterránea.',
    image: 'https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=600&q=80',
    href: '/catas',
  },
]
---
<section class="py-32" style="background: var(--color-bg-card);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-16" data-reveal>
      <span class="text-xs tracking-[0.3em] uppercase" style="font-family: var(--font-family-body); color: var(--color-gold);">Lo que ofrecemos</span>
      <span class="gold-divider mt-3" style="margin-left: auto; margin-right: auto;"></span>
      <h2 class="section-heading mt-2">Nuestros <span style="color: var(--color-gold);">Eventos</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {events.map((event, i) => (
        <a
          href={event.href}
          class="group block overflow-hidden transition-all duration-300"
          style="border: 1px solid var(--color-bg-border); background: white;"
          data-reveal
          data-delay={String(i * 100)}
          onmouseover="this.style.borderColor='rgba(187,146,58,0.4)'; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'"
          onmouseout="this.style.borderColor='var(--color-bg-border)'; this.style.boxShadow=''"
        >
          <div class="overflow-hidden" style="aspect-ratio: 3/2;">
            <img
              src={event.image}
              alt={event.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <h3 class="text-xl mb-2 transition-colors duration-200" style="font-family: var(--font-family-display); color: var(--color-dark);">
              {event.title}
            </h3>
            <p class="text-sm leading-relaxed" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">
              {event.description}
            </p>
            <span class="inline-flex items-center gap-2 mt-4 text-xs tracking-widest uppercase transition-all duration-200 group-hover:gap-3"
                  style="font-family: var(--font-family-body); color: var(--color-gold);">
              Ver más
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
