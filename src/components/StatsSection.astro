---
const stats = [
  { value: '30', suffix: '+', label: 'Años de experiencia' },
  { value: '5', suffix: '', label: 'Servicios especializados' },
  { value: '692', suffix: '+', label: 'Comensales satisfechos' },
]
---
<section id="servicios" class="py-24" style="background: var(--color-bg-card); border-top: 1px solid var(--color-bg-border); border-bottom: 1px solid var(--color-bg-border);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mx-auto text-center mb-16" data-reveal>
      <span class="gold-divider" style="margin-left: auto; margin-right: auto;"></span>
      <p class="text-lg leading-relaxed" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.6);">
        Nos hemos especializado en eventos corporativos donde contamos con más de 30 años de experiencia.
        Cada celebración es única, especial y singular.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 1px; background: var(--color-bg-border);">
      {stats.map((stat, i) => (
        <div
          class="p-12 text-center group transition-colors duration-300"
          style="background: var(--color-bg-card);"
          data-reveal
          data-delay={String(i * 100)}
          onmouseover="this.style.background='white'"
          onmouseout="this.style.background='var(--color-bg-card)'"
        >
          <div class="font-semibold mb-3" style="font-family: var(--font-family-display); font-size: clamp(3.5rem, 7vw, 5rem); color: var(--color-gold);">
            {stat.value}<span style="color: rgba(187,146,58,0.5);">{stat.suffix}</span>
          </div>
          <div class="text-sm tracking-widest uppercase" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
