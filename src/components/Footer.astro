---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Eventos', href: '/eventos' },
  { label: 'Espacios', href: '/espacios' },
  { label: 'Bodas', href: '/bodas' },
  { label: 'Catas Magistrales', href: '/catas' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
]
---
<footer style="background: var(--color-dark); border-top: 1px solid var(--color-dark-border);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div>
        <a href="/" style="font-family: var(--font-family-display); font-size: 1.5rem; font-weight: 600; color: white; text-decoration: none;">
          Cobos <span style="color: var(--color-gold);">Catering</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed" style="color: rgba(255,255,255,0.5); font-family: var(--font-family-body);">
          Más de 30 años de experiencia creando experiencias gastronómicas únicas para cada celebración.
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <h4 class="text-lg mb-4" style="font-family: var(--font-family-display); color: var(--color-gold);">Navegación</h4>
        <ul class="space-y-2">
          {navItems.map(item => (
            <li>
              <a
                href={item.href}
                class="text-sm tracking-wide hover:underline transition-colors"
                style="color: rgba(255,255,255,0.5); font-family: var(--font-family-body);"
                onmouseover="this.style.color='var(--color-gold)'"
                onmouseout="this.style.color='rgba(255,255,255,0.5)'"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="text-lg mb-4" style="font-family: var(--font-family-display); color: var(--color-gold);">Contacto</h4>
        <div class="space-y-3 text-sm" style="color: rgba(255,255,255,0.5); font-family: var(--font-family-body);">
          <p>Hablemos sobre tu próximo evento</p>
          <a href="/contacto" class="btn-gold text-xs mt-4 inline-flex">
            Contactar ahora
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-top: 1px solid var(--color-dark-border);">
      <p class="text-xs" style="color: rgba(255,255,255,0.3); font-family: var(--font-family-body);">
        © {new Date().getFullYear()} Cobos Catering. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        {['Política de cookies', 'Aviso legal', 'Política de privacidad'].map(item => (
          <a href="#" class="text-xs hover:underline transition-colors"
             style="color: rgba(255,255,255,0.3); font-family: var(--font-family-body);"
             onmouseover="this.style.color='var(--color-gold)'"
             onmouseout="this.style.color='rgba(255,255,255,0.3)'"
          >
            {item}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
