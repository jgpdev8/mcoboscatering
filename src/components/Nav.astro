---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/espacios', label: 'Espacios' },
  { href: '/bodas', label: 'Bodas' },
  { href: '/catas', label: 'Catas Magistrales' },
  { href: '/blog', label: 'Blog' },
  { href: '/contacto', label: 'Contacto' },
]

const currentPath = Astro.url.pathname
---
<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="font-display text-2xl font-semibold text-white tracking-wide hover:text-gold transition-colors" style="font-family: var(--font-family-display);">
        Cobos <span style="color: var(--color-gold);">Catering</span>
      </a>

      <!-- Desktop Menu -->
      <ul class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`text-sm tracking-widest uppercase transition-colors duration-200 ${
                currentPath === link.href
                  ? 'text-gold'
                  : 'text-white/70 hover:text-gold'
              }`}
              style={currentPath === link.href ? `color: var(--color-gold); font-family: var(--font-family-body);` : `font-family: var(--font-family-body);`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <a href="/contacto" class="hidden lg:inline-flex btn-gold text-xs">
        Solicitar presupuesto
      </a>

      <!-- Mobile hamburger -->
      <button id="menu-toggle" class="lg:hidden text-white p-2" aria-label="Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden backdrop-blur-md border-t" style="background: rgba(17,17,17,0.95); border-color: var(--color-dark-border);">
    <ul class="px-6 py-4 space-y-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-sm tracking-widest uppercase text-white/70 hover:text-gold transition-colors py-2" style="font-family: var(--font-family-body);">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav.style.background = 'rgba(17,17,17,0.95)'
      nav.style.backdropFilter = 'blur(12px)'
      nav.style.borderBottom = '1px solid #2A2A2A'
    } else {
      nav.style.background = ''
      nav.style.backdropFilter = ''
      nav.style.borderBottom = ''
    }
  })

  const toggle = document.getElementById('menu-toggle')!
  const menu = document.getElementById('mobile-menu')!
  toggle.addEventListener('click', () => menu.classList.toggle('hidden'))
</script>
