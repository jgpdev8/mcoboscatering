---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Contacto" description="Contacta con Cobos Catering para solicitar presupuesto para tu evento.">
  <!-- Hero -->
  <div class="pt-44 pb-20" style="background: var(--color-bg-card); border-bottom: 1px solid var(--color-bg-border);">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <span class="text-xs tracking-[0.3em] uppercase" style="font-family: var(--font-family-body); color: var(--color-gold);">Hablemos</span>
      <span class="gold-divider" style="margin: 1.5rem auto;"></span>
      <h1 class="section-heading">
        Cuéntanos tu <span style="color: var(--color-gold);">proyecto</span>
      </h1>
    </div>
  </div>

  <!-- Form section -->
  <section class="py-32">
    <div class="max-w-3xl mx-auto px-6 lg:px-12">
      <form class="space-y-8" action="#" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">Nombre *</label>
            <input type="text" required name="nombre"
              class="w-full px-4 py-3 text-sm text-white outline-none transition-colors duration-200"
              style="background: transparent; border: 1px solid var(--color-bg-border); font-family: var(--font-family-body);"
              onfocus="this.style.borderColor='var(--color-gold)'"
              onblur="this.style.borderColor='var(--color-bg-border)'"
            />
          </div>
          <div>
            <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">Email *</label>
            <input type="email" required name="email"
              class="w-full px-4 py-3 text-sm text-white outline-none transition-colors duration-200"
              style="background: transparent; border: 1px solid var(--color-bg-border); font-family: var(--font-family-body);"
              onfocus="this.style.borderColor='var(--color-gold)'"
              onblur="this.style.borderColor='var(--color-bg-border)'"
            />
          </div>
        </div>
        <div>
          <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">Tipo de evento</label>
          <select name="tipo_evento"
            class="w-full px-4 py-3 text-sm text-white outline-none transition-colors duration-200"
            style="background: var(--color-bg-card); border: 1px solid var(--color-bg-border); font-family: var(--font-family-body);"
            onfocus="this.style.borderColor='var(--color-gold)'"
            onblur="this.style.borderColor='var(--color-bg-border)'"
          >
            <option value="">Seleccionar...</option>
            <option>Evento corporativo</option>
            <option>Boda</option>
            <option>Cata magistral</option>
            <option>Otro</option>
          </select>
        </div>
        <div>
          <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">Mensaje *</label>
          <textarea required name="mensaje" rows="6"
            class="w-full px-4 py-3 text-sm text-white outline-none transition-colors duration-200 resize-none"
            style="background: transparent; border: 1px solid var(--color-bg-border); font-family: var(--font-family-body);"
            onfocus="this.style.borderColor='var(--color-gold)'"
            onblur="this.style.borderColor='var(--color-bg-border)'"
          ></textarea>
        </div>
        <button type="submit" class="btn-gold w-full justify-center">
          Enviar solicitud
        </button>
      </form>
    </div>
  </section>
</Layout>
