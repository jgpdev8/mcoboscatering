---
import Layout from '../layouts/Layout.astro'

const items = [
  { title: 'Banquetes Nupciales', desc: 'Menús exquisitos diseñados especialmente para el día más importante de tu vida.', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=80' },
  { title: 'Cócteles de Boda', desc: 'Aperitivos y bebidas de alta gama para recibir a tus invitados con estilo.', img: 'https://images.unsplash.com/photo-1543007631-283050bb3e8c?w=800&q=80' },
  { title: 'Decoración y Ambientación', desc: 'Creamos el ambiente perfecto para que tu boda sea un sueño hecho realidad.', img: 'https://images.unsplash.com/photo-1478146522998-8af70e3e6e74?w=800&q=80' },
]
---
<Layout title="Bodas" description="Bodas perfectas con Cobos Catering. El catering de bodas más exclusivo.">
  <div class="pt-44 pb-20" style="background: var(--color-bg-card); border-bottom: 1px solid var(--color-bg-border);">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-xs tracking-[0.3em] uppercase" style="font-family: var(--font-family-body); color: var(--color-gold);">El día más especial</span>
      <span class="gold-divider" style="margin: 1.5rem auto;"></span>
      <h1 class="section-heading">
        Bodas <span style="color: var(--color-gold);">Perfectas</span>
      </h1>
    </div>
  </div>

  <section class="py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mx-auto text-center mb-16" data-reveal>
        <p class="text-lg leading-relaxed" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.6);">
          Cuéntanos qué te gustaría conseguir y nosotros nos encargamos del resto.
          Llevamos más de 30 años haciendo realidad el sueño de miles de parejas.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {items.map((item, i) => (
          <div
            class="overflow-hidden group"
            style="border: 1px solid var(--color-bg-border);"
            data-reveal
            data-delay={String(i * 100)}
          >
            <div class="overflow-hidden" style="aspect-ratio: 3/2;">
              <img src={item.img} alt={item.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="text-xl mb-2" style="font-family: var(--font-family-display); color: var(--color-dark);">{item.title}</h3>
              <p class="text-sm" style="font-family: var(--font-family-body); color: rgba(0,0,0,0.5);">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-16">
        <a href="/contacto" class="btn-gold">Solicitar información de bodas</a>
      </div>
    </div>
  </section>
</Layout>
