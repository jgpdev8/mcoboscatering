---
import Layout from '../../layouts/Layout.astro'

const posts = [
  {
    title: '5 tendencias en catering para 2024',
    excerpt: 'Descubre las últimas tendencias gastronómicas que están marcando los eventos más exclusivos.',
    date: '15 Marzo 2024',
    img: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80',
    category: 'Tendencias',
  },
  {
    title: 'Cómo elegir el catering perfecto para tu boda',
    excerpt: 'Guía completa para tomar la mejor decisión gastronómica en el día más especial de tu vida.',
    date: '8 Febrero 2024',
    img: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=600&q=80',
    category: 'Bodas',
  },
  {
    title: 'La gastronomía mediterránea en eventos corporativos',
    excerpt: 'Por qué la cocina mediterránea es la opción ideal para impresionar a tus clientes y socios.',
    date: '20 Enero 2024',
    img: 'https://images.unsplash.com/photo-1511578314322-379afb476865?w=600&q=80',
    category: 'Corporativo',
  },
]
---
<Layout title="Blog" description="Blog de Cobos Catering: tendencias, consejos y novedades gastronómicas.">
  <div class="pt-40 pb-20" style="background: var(--color-dark-card); border-bottom: 1px solid var(--color-dark-border);">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-xs tracking-[0.3em] uppercase" style="font-family: var(--font-family-body); color: var(--color-gold);">Noticias y consejos</span>
      <span class="gold-divider" style="margin: 1.5rem auto;"></span>
      <h1 class="section-heading">
        Nuestro <span style="color: var(--color-gold);">Blog</span>
      </h1>
    </div>
  </div>

  <section class="py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <article
            class="overflow-hidden group cursor-pointer"
            style="border: 1px solid var(--color-dark-border);"
            data-reveal
            data-delay={String(i * 100)}
          >
            <div class="overflow-hidden" style="aspect-ratio: 3/2;">
              <img src={post.img} alt={post.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs px-2 py-1" style="background: rgba(187,146,58,0.1); color: var(--color-gold); font-family: var(--font-family-body);">{post.category}</span>
                <span class="text-xs" style="color: rgba(255,255,255,0.3); font-family: var(--font-family-body);">{post.date}</span>
              </div>
              <h3 class="text-xl mb-2 transition-colors duration-200 group-hover:text-gold" style="font-family: var(--font-family-display); color: white;">{post.title}</h3>
              <p class="text-sm leading-relaxed" style="font-family: var(--font-family-body); color: rgba(255,255,255,0.5);">{post.excerpt}</p>
              <span class="inline-flex items-center gap-2 mt-4 text-xs tracking-widest uppercase transition-all duration-200 group-hover:gap-3"
                    style="font-family: var(--font-family-body); color: var(--color-gold);">
                Leer más
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
